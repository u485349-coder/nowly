generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AvailabilityState {
  FREE_NOW
  FREE_LATER
  BUSY
  DOWN_THIS_WEEKEND
}

enum AvailabilityRecurrence {
  WEEKLY
  MONTHLY
}

enum Vibe {
  FOOD
  GYM
  CHILL
  PARTY
  COFFEE
  OUTDOORS
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum BudgetMood {
  LOW_SPEND
  FLEXIBLE
  TREAT_MYSELF
}

enum SocialBattery {
  LOW_KEY
  OPEN
  SOCIAL
}

enum HangoutIntent {
  QUICK_BITE
  COFFEE_RUN
  WALK_NEARBY
  STUDY_SPRINT
  PULL_UP
  WORKOUT
  QUICK_CHILL
}

enum MicroCommitment {
  DROP_IN
  QUICK_WINDOW
  OPEN_ENDED
}

enum MicroResponse {
  PULLING_UP
  TEN_MIN_ONLY
  MAYBE_LATER
  PASS
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum HangoutStatus {
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ParticipantResponse {
  PENDING
  ACCEPTED
  SUGGESTED_CHANGE
  DECLINED
}

enum MessageType {
  TEXT
  SYSTEM
  ETA
  LOCATION
  POLL
  REACTION
}

enum NotificationType {
  OVERLAP_FOUND
  PROPOSAL_RECEIVED
  PROPOSAL_ACCEPTED
  GROUP_UPDATE
  ETA_UPDATE
  RECAP_READY
  REMINDER
  INVITE_NUDGE
  WEEKLY_SUMMARY
}

enum NotificationPriority {
  HIGH
  LOW
}

enum NotificationIntensity {
  QUIET
  BALANCED
  LIVE
}

enum PushReceiptStatus {
  PENDING
  OK
  ERROR
}

enum InviteChannel {
  SMS
  DISCORD
  LINK
}

enum DiscordPresence {
  ONLINE
  IDLE
  DND
  OFFLINE
  UNKNOWN
}

enum MatchStatus {
  OPEN
  DISMISSED
  CONVERTED
  EXPIRED
}

enum SchedulingType {
  ONE_ON_ONE
  GROUP
}

enum SchedulingDecisionMode {
  INSTANT_CONFIRM
  EVERYONE_AGREES
  MINIMUM_REQUIRED
  HOST_DECIDES
}

enum SchedulingVisibilityMode {
  PUBLIC
  ANONYMOUS
}

enum SchedulingSessionStatus {
  OPEN
  LOCKED
  FINALIZED
  EXPIRED
  CANCELLED
}

enum SchedulingVoteState {
  AVAILABLE
  MAYBE
  UNAVAILABLE
}

model User {
  id                  String                    @id @default(cuid())
  phone               String                    @unique
  name                String?
  photoUrl            String?
  city                String?
  communityTag        String?
  lat                 Float?
  lng                 Float?
  responsivenessScore Float                     @default(0.55)
  onboardingCompleted Boolean                   @default(false)
  inviteCode          String                    @unique @default(cuid())
  discordId           String?                   @unique
  discordUsername     String?
  discordAvatar       String?
  discordPresence     DiscordPresence?
  sharedServerCount   Int                       @default(0)
  notificationIntensity NotificationIntensity   @default(BALANCED)
  inactiveSince       DateTime?
  referredById        String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  referredBy          User?                     @relation("UserReferrals", fields: [referredById], references: [id])
  referrals           User[]                    @relation("UserReferrals")
  otpCodes            OtpCode[]
  deviceTokens        DeviceToken[]
  pushReceipts        PushReceipt[]
  availabilitySignals AvailabilitySignal[]
  recurringWindows    RecurringAvailabilityWindow[]
  friendshipsA        Friendship[]              @relation("FriendshipUserA")
  friendshipsB        Friendship[]              @relation("FriendshipUserB")
  hangoutsCreated     Hangout[]                 @relation("HangoutCreator")
  hangoutParticipants HangoutParticipant[]
  messages            Message[]
  directThreadMemberships DirectThreadParticipant[]
  directMessagesSent  DirectMessage[]           @relation("DirectMessageSender")
  createdDirectThreads DirectThread[]           @relation("DirectThreadCreator")
  analyticsEvents     AnalyticsEvent[]
  notificationLogs    NotificationLog[]
  sentInvitations     Invitation[]              @relation("InvitationSender")
  joinedInvitations   Invitation[]              @relation("InvitationJoinedUser")
  overlapMatches      OverlapMatch[]            @relation("OverlapMatchUser")
  matchedInOverlaps   OverlapMatch[]            @relation("OverlapMatchMatchedUser")
  discordConnections  DiscordServerConnection[]
  recapMemories       RecapMemory[]             @relation("RecapOwner")
  hostedSchedulingSessions SchedulingSession[]  @relation("SchedulingSessionHost")
  schedulingSessionParticipants SchedulingSessionParticipant[]
}

model OtpCode {
  id         String   @id @default(cuid())
  phone      String
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  userId     String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([phone, expiresAt])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  pushReceipts PushReceipt[]

  @@index([userId, active])
}

model PushReceipt {
  id            String            @id @default(cuid())
  receiptId     String            @unique
  userId        String
  deviceTokenId String
  notificationType NotificationType
  status        PushReceiptStatus @default(PENDING)
  errorCode     String?
  errorMessage  String?
  payload       Json?
  createdAt     DateTime          @default(now())
  checkedAt     DateTime?
  resolvedAt    DateTime?
  user          User              @relation(fields: [userId], references: [id])
  deviceToken   DeviceToken       @relation(fields: [deviceTokenId], references: [id])

  @@index([status, createdAt])
  @@index([userId, notificationType, createdAt])
}

model AvailabilitySignal {
  id            String            @id @default(cuid())
  userId        String
  state         AvailabilityState
  label         String?
  radiusKm      Int               @default(8)
  vibe          Vibe?
  energyLevel   EnergyLevel?
  budgetMood    BudgetMood?
  socialBattery SocialBattery?
  hangoutIntent HangoutIntent?
  expiresAt     DateTime
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id])
  sourceMatches OverlapMatch[]    @relation("OverlapSignal")
  targetMatches OverlapMatch[]    @relation("MatchedOverlapSignal")

  @@index([userId, isActive, expiresAt])
}

model RecurringAvailabilityWindow {
  id               String                 @id @default(cuid())
  userId           String
  recurrence       AvailabilityRecurrence
  dayOfWeek        Int?
  dayOfMonth       Int?
  startMinute      Int
  endMinute        Int
  utcOffsetMinutes Int                    @default(0)
  label            String?
  vibe             Vibe?
  hangoutIntent    HangoutIntent?
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  user             User                   @relation(fields: [userId], references: [id])

  @@unique([userId, recurrence, dayOfWeek, dayOfMonth, startMinute, endMinute])
  @@index([userId, isActive, recurrence])
}

model Friendship {
  id          String           @id @default(cuid())
  userAId     String
  userBId     String
  status      FriendshipStatus @default(PENDING)
  initiatedBy String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userA       User             @relation("FriendshipUserA", fields: [userAId], references: [id])
  userB       User             @relation("FriendshipUserB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
}

model Hangout {
  id           String               @id @default(cuid())
  creatorId    String
  status       HangoutStatus        @default(PROPOSED)
  activity     String
  microType    HangoutIntent?
  commitmentLevel MicroCommitment   @default(DROP_IN)
  locationName String
  locationLat  Float?
  locationLng  Float?
  scheduledFor DateTime
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  creator      User                 @relation("HangoutCreator", fields: [creatorId], references: [id])
  participants HangoutParticipant[]
  thread       HangoutThread?
  recapMemory  RecapMemory?
  finalizedFromSessions SchedulingSession[] @relation("SchedulingSessionFinalHangout")

  @@index([creatorId, status])
  @@index([scheduledFor])
}

model HangoutThread {
  id            String    @id @default(cuid())
  hangoutId     String    @unique
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  hangout       Hangout   @relation(fields: [hangoutId], references: [id])
  messages      Message[]
}

model DirectThread {
  id             String                    @id @default(cuid())
  participantKey String?                   @unique
  type           String                    @default("direct")
  title          String?
  imageUrl       String?
  creatorId      String?
  lastMessageAt  DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  creator        User?                     @relation("DirectThreadCreator", fields: [creatorId], references: [id])
  participants   DirectThreadParticipant[]
  messages       DirectMessage[]

  @@index([creatorId, createdAt])
}

model DirectThreadParticipant {
  threadId  String
  userId    String
  joinedAt  DateTime      @default(now())
  lastReadAt DateTime?
  thread    DirectThread  @relation(fields: [threadId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@id([threadId, userId])
  @@index([userId, joinedAt])
}

model HangoutParticipant {
  hangoutId      String
  userId         String
  responseStatus ParticipantResponse @default(PENDING)
  microResponse  MicroResponse?
  respondedAt    DateTime?
  etaMinutes     Int?
  lastSharedLat  Float?
  lastSharedLng  Float?
  joinedAt       DateTime            @default(now())
  hangout        Hangout             @relation(fields: [hangoutId], references: [id])
  user           User                @relation(fields: [userId], references: [id])

  @@id([hangoutId, userId])
  @@index([userId, responseStatus])
}

model Message {
  id        String       @id @default(cuid())
  threadId  String
  senderId  String
  text      String
  type      MessageType  @default(TEXT)
  metadata  Json?
  createdAt DateTime     @default(now())
  thread    HangoutThread @relation(fields: [threadId], references: [id])
  sender    User         @relation(fields: [senderId], references: [id])

  @@index([threadId, createdAt])
}

model DirectMessage {
  id        String       @id @default(cuid())
  threadId  String
  senderId  String
  text      String
  type      MessageType  @default(TEXT)
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  thread    DirectThread @relation(fields: [threadId], references: [id])
  sender    User         @relation("DirectMessageSender", fields: [senderId], references: [id])

  @@index([threadId, createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  payload   Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([event, createdAt])
}

model NotificationLog {
  id        String               @id @default(cuid())
  userId    String
  type      NotificationType
  priority  NotificationPriority
  dedupeKey String
  payload   Json?
  sentAt    DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id])

  @@unique([userId, type, dedupeKey])
  @@index([userId, sentAt])
}

model Invitation {
  id            String        @id @default(cuid())
  inviterId     String
  joinedUserId  String?
  inviteePhone  String?
  channel       InviteChannel
  deepLinkToken String        @unique @default(cuid())
  context       Json?
  createdAt     DateTime      @default(now())
  redeemedAt    DateTime?
  inviter       User          @relation("InvitationSender", fields: [inviterId], references: [id])
  joinedUser    User?         @relation("InvitationJoinedUser", fields: [joinedUserId], references: [id])
}

model DiscordServerConnection {
  id        String   @id @default(cuid())
  userId    String
  serverId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, serverId])
  @@index([serverId])
}

model OverlapMatch {
  id              String             @id @default(cuid())
  userId          String
  matchedUserId   String
  signalId        String
  matchedSignalId String
  score           Float
  reason          Json
  status          MatchStatus        @default(OPEN)
  notifiedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation("OverlapMatchUser", fields: [userId], references: [id])
  matchedUser     User               @relation("OverlapMatchMatchedUser", fields: [matchedUserId], references: [id])
  signal          AvailabilitySignal @relation("OverlapSignal", fields: [signalId], references: [id])
  matchedSignal   AvailabilitySignal @relation("MatchedOverlapSignal", fields: [matchedSignalId], references: [id])

  @@unique([userId, matchedUserId, signalId, matchedSignalId])
  @@index([userId, status, expiresAt])
}

model RecapMemory {
  id           String   @id @default(cuid())
  hangoutId    String   @unique
  ownerId      String
  title        String
  summary      String
  photoDropUrl String?
  streakCount  Int      @default(1)
  sharePayload Json?
  createdAt    DateTime @default(now())
  hangout      Hangout  @relation(fields: [hangoutId], references: [id])
  owner        User     @relation("RecapOwner", fields: [ownerId], references: [id])
}

model SchedulingSession {
  id                   String                   @id @default(cuid())
  shareCode            String                   @unique @default(cuid())
  hostId               String
  schedulingType       SchedulingType           @default(GROUP)
  status               SchedulingSessionStatus  @default(OPEN)
  title                String
  description          String                   @default("")
  locationName         String
  durationMinutes      Int
  timezone             String
  participantCap       Int                      @default(4)
  minimumConfirmations Int                      @default(3)
  decisionMode         SchedulingDecisionMode   @default(MINIMUM_REQUIRED)
  visibilityMode       SchedulingVisibilityMode @default(PUBLIC)
  responseDeadline     DateTime?
  pollLockedAt         DateTime?
  finalizedAt          DateTime?
  finalizedSlotId      String?
  finalHangoutId       String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  host                 User                     @relation("SchedulingSessionHost", fields: [hostId], references: [id])
  finalHangout         Hangout?                 @relation("SchedulingSessionFinalHangout", fields: [finalHangoutId], references: [id])
  finalizedSlot        SchedulingSessionSlot?   @relation("SchedulingSessionFinalSlot", fields: [finalizedSlotId], references: [id])
  slots                SchedulingSessionSlot[]
  participants         SchedulingSessionParticipant[]
  messages             SchedulingSessionMessage[]

  @@index([hostId, createdAt])
  @@index([shareCode, status])
}

model SchedulingSessionSlot {
  id                 String                @id @default(cuid())
  sessionId          String
  startsAt           DateTime
  endsAt             DateTime
  sortOrder          Int                   @default(0)
  createdAt          DateTime              @default(now())
  session            SchedulingSession     @relation(fields: [sessionId], references: [id])
  votes              SchedulingSessionVote[]
  finalizedInSession SchedulingSession[]   @relation("SchedulingSessionFinalSlot")

  @@unique([sessionId, startsAt, endsAt])
  @@index([sessionId, startsAt])
}

model SchedulingSessionParticipant {
  id                     String                    @id @default(cuid())
  sessionId              String
  userId                 String
  isHost                 Boolean                   @default(false)
  collaborationIndex     Int                       @default(0)
  hasSubmittedAvailability Boolean                 @default(false)
  submittedAt            DateTime?
  joinedAt               DateTime                  @default(now())
  lastActiveAt           DateTime?
  session                SchedulingSession         @relation(fields: [sessionId], references: [id])
  user                   User                      @relation(fields: [userId], references: [id])
  votes                  SchedulingSessionVote[]
  messages               SchedulingSessionMessage[]

  @@unique([sessionId, userId])
  @@index([userId, joinedAt])
}

model SchedulingSessionVote {
  id            String                       @id @default(cuid())
  sessionId     String
  slotId        String
  participantId String
  status        SchedulingVoteState
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  session       SchedulingSession            @relation(fields: [sessionId], references: [id])
  slot          SchedulingSessionSlot        @relation(fields: [slotId], references: [id])
  participant   SchedulingSessionParticipant @relation(fields: [participantId], references: [id])

  @@unique([slotId, participantId])
  @@index([sessionId, slotId])
}

model SchedulingSessionMessage {
  id                  String                       @id @default(cuid())
  sessionId           String
  senderParticipantId String?
  text                String
  type                MessageType                 @default(TEXT)
  metadata            Json?
  createdAt           DateTime                    @default(now())
  session             SchedulingSession           @relation(fields: [sessionId], references: [id])
  senderParticipant   SchedulingSessionParticipant? @relation(fields: [senderParticipantId], references: [id])

  @@index([sessionId, createdAt])
}
