{
  "expo": {
    "name": "Nowly",
    "description": "Don't grow apart. Nowly turns overlapping availability into spontaneous hangouts before the moment slips.",
    "slug": "nowly",
    "scheme": "nowly",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Nowly uses your photos so you can add a profile picture your friends recognize instantly.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22D3EE"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nowly.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.nowly.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/adaptive-icon-monochrome.png",
        "backgroundColor": "#0B1020"
      }
    },
    "web": {
      "favicon": "./assets/favicon-marketing.png"
    },
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1020"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5d10e21-6062-4975-9a40-1b2595e59064"
      }
    },
    "owner": "activez"
  }
}

